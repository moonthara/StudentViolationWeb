@page "/guard/"

@inject NavigationManager Nav
@inject AuthService AuthService
@inject GuardService GuardService
@inject ISnackbar Snackbar

<PageTitle>Guard Dashboard</PageTitle>

<MudLayout>
    <!-- TOP APP BAR -->
    <MudAppBar Elevation="0" Style="background: rgba(7,13,28,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.10);">
        <MudText Typo="Typo.h6" Style="font-weight:600; color:white; letter-spacing:0.01em;">Guard Dashboard</MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Style="background:rgba(37,99,235,0.3); color:#93c5fd; border:1px solid rgba(59,130,246,0.4); font-size:11px;">ACLC</MudChip>
        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" Style="color:rgba(255,255,255,0.7);" />
    </MudAppBar>

    <MudMainContent Style="background: #04060f; min-height: 100vh; padding-bottom: 80px;">

        <!-- BACKGROUND EFFECTS -->
        <div style="position:fixed; inset:0; background: radial-gradient(ellipse 60% 50% at 20% 10%, rgba(37,99,235,0.18) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 80% 80%, rgba(37,99,235,0.10) 0%, transparent 60%); pointer-events:none; z-index:0;"></div>
        <div style="position:fixed; inset:0; background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size:40px 40px; pointer-events:none; z-index:0;"></div>

        <MudContainer MaxWidth="MaxWidth.Small" Style="position:relative; z-index:1; padding-top:16px;">

            <!-- WELCOME BANNER -->
            <div style="background: linear-gradient(135deg, rgba(37,99,235,0.25), rgba(37,99,235,0.10)); border: 1px solid rgba(59,130,246,0.30); border-radius: 16px; padding: 16px 20px; margin-bottom: 20px; display:flex; align-items:center; gap:16px;">
                <div style="width:44px; height:44px; border-radius:12px; background:rgba(59,130,246,0.25); border:1px solid rgba(59,130,246,0.4); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <MudIcon Icon="@Icons.Material.Filled.Shield" Style="color:#93c5fd;" />
                </div>
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600; color:white;">Welcome, Login successful!</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(147,197,253,0.8);">Tap the QR button to scan or enter a student number</MudText>
                </div>
            </div>

            <!-- NAV TABS -->
            <MudTabs @bind-ActivePanelIndex="_activeTab"
                     Elevation="0"
                     Style="background:transparent;"
                     TabPanelClass="pa-0"
                     SliderColor="Color.Primary"
                     PanelClass="pt-4">

                <!-- TAB 1: RECORD VIOLATION -->
                <MudTabPanel Text="Record" Icon="@Icons.Material.Filled.AddCircle" Style="color:rgba(255,255,255,0.7);">
                    <RecordViolationTab />
                </MudTabPanel>

                <!-- TAB 2: VIOLATION HISTORY -->
                <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History" Style="color:rgba(255,255,255,0.7);">
                    <ViolationHistoryTab />
                </MudTabPanel>

                <!-- TAB 3: SUMMARY -->
                <MudTabPanel Text="Summary" Icon="@Icons.Material.Filled.BarChart" Style="color:rgba(255,255,255,0.7);">
                    <ViolationSummaryTab />
                </MudTabPanel>

                <!-- TAB 4: ALL STUDENTS -->
                <MudTabPanel Text="Students" Icon="@Icons.Material.Filled.People" Style="color:rgba(255,255,255,0.7);">
                    <AllStudentsTab />
                </MudTabPanel>

            </MudTabs>
        </MudContainer>
    </MudMainContent>

    <!-- BOTTOM FAB - QR SCANNER -->
    <div style="position:fixed; bottom:20px; left:50%; transform:translateX(-50%); z-index:200;">
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.QrCodeScanner"
                Style="background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 20px rgba(37,99,235,0.5);"
                OnClick="OpenQrModal" />
    </div>

    <!-- QR SCANNER DIALOG -->
    <MudDialog @bind-IsVisible="_qrModalOpen" Options="_qrDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6" Style="color:white; display:flex; align-items:center; gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Style="color:#93c5fd;" />
                Validate Student
            </MudText>
        </TitleContent>
        <DialogContent>
            <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.10); border-radius:14px; padding:20px; display:flex; align-items:center; justify-content:center; min-height:130px; margin-bottom:16px;">
                <div style="text-align:center; color:rgba(255,255,255,0.4);">
                    <MudIcon Icon="@Icons.Material.Filled.QrCode" Style="font-size:44px; opacity:0.5;" />
                    <MudText Typo="Typo.caption" Style="display:block; margin-top:6px;">Camera on mobile only</MudText>
                </div>
            </div>
            <MudDivider Style="border-color:rgba(255,255,255,0.10);" />
            <MudText Typo="Typo.caption" Align="Align.Center" Style="color:rgba(255,255,255,0.5); display:block; margin:10px 0;">OR enter manually</MudText>
            <MudTextField @bind-Value="_manualStudentNo"
                          Placeholder="e.g. C26-01-0001-MAN121"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.School"
                          Style="--mud-palette-text-primary:rgba(255,255,255,0.8);"
                          Class="glass-input" />
            @if (_validateError != null)
            {
                <MudAlert Severity="Severity.Error" Style="margin-top:8px; background:rgba(239,68,68,0.15); color:#fca5a5; border:1px solid rgba(239,68,68,0.3);">@_validateError</MudAlert>
            }
            @if (_validatedStudent is not null)
            {
                var student = _validatedStudent;
                <MudPaper Elevation="0" Style="background:rgba(16,185,129,0.10); border:1px solid rgba(16,185,129,0.3); border-radius:12px; padding:12px; margin-top:10px;">
                    <MudText Typo="Typo.subtitle2" Style="color:#6ee7b7;">✓ Student Found</MudText>
                    <MudText Typo="Typo.body2" Style="color:white;">@student.FirstName @student.LastName</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.5);">@student.StudentNo · @student.Course @student.Year</MudText>
                </MudPaper>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseQrModal"
                       Style="border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.8); border-radius:10px;">
                Close
            </MudButton>
            <MudButton Variant="Variant.Filled" OnClick="ValidateStudent"
                       Disabled="_validating"
                       Style="background:linear-gradient(135deg,#2563eb,#1d4ed8); color:white; border-radius:10px; box-shadow:0 4px 16px rgba(37,99,235,0.3);">
                @if (_validating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }
                else
                {
                    <span>✓ Validate</span>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudLayout>

@code {
    private int _activeTab = 0;
    private bool _qrModalOpen = false;
    private string _manualStudentNo = "";
    private bool _validating = false;
    private string? _validateError = null;
    private StudentModel? _validatedStudent = null;

    private DialogOptions _qrDialogOptions = new()
    {
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true,
        BackdropClick = true,
        CloseButton = false,
        BackgroundClass = "qr-backdrop"
    };

    private void OpenQrModal()
    {
        _qrModalOpen = true;
        _manualStudentNo = "";
        _validateError = null;
        _validatedStudent = null;
    }

    private void CloseQrModal() => _qrModalOpen = false;

    private async Task ValidateStudent()
    {
        if (string.IsNullOrWhiteSpace(_manualStudentNo)) return;
        _validating = true;
        _validateError = null;
        _validatedStudent = null;

        var result = await GuardService.ValidateStudentAsync(_manualStudentNo.Trim().ToUpper());
        _validating = false;

        if (result.Status == 200 && result.Data != null)
        {
            _validatedStudent = result.Data;
        }
        else
        {
            _validateError = result.Message ?? "Student not found.";
        }
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Nav.NavigateTo("/login");
    }
}
