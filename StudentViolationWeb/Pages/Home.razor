@page "/home"
@page "/"


<MudPaper Height="100vh" Width="100%" Elevation="0"
          Style="display: flex; align-items: center; justify-content: center; background: #f5f5f5;">

    
    <div style="width: 900px; height: 520px; border-radius: 16px; overflow: hidden;
                display: flex; box-shadow: 0 4px 20px rgba(0,0,0,0.15);">

        @* LEFT PANEL *@
        <div style="width: 340px; background: #003262; display: flex; flex-direction: column;
                    align-items: center; justify-content: center; padding: 48px 32px; color: white; flex-shrink: 0;">
            <MudIcon Icon="@Icons.Material.Filled.School"
                     Style="font-size: 80px; color: white; margin-bottom: 16px;" />
            <MudText Typo="Typo.h4" Align="Align.Center"
                     Style="color: white; font-weight: 700; margin-bottom: 12px;">
                Student Violation
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: rgba(255,255,255,0.75);">
                Manage and track student violations efficiently and transparently.
            </MudText>
        </div>

        @*  RIGHT PANEL *@
        <div style="flex: 1; display: flex; flex-direction: column;
                    justify-content: flex-start; padding: 40px 40px 32px 40px;
                    background: white; overflow-y: auto;">

            <MudText Typo="Typo.h4" Style="font-weight: 700; margin-bottom: 28px;">
                Login<Login />
            </MudText>

            <MudForm @ref="form" @bind-IsValid="isValid">

                <MudTextField T="string"
                              Label="Username"
                              @bind-Value="username"
                              Required="true"
                              RequiredError="Username is required"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-4" />

                <MudTextField T="string"
                              Label="Password"
                              @bind-Value="password"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="@pwdType"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@pwdIcon"
                              OnAdornmentClick="TogglePassword"
                              Class="mb-2" />

                <MudStack Row="true" Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center" Class="mb-4">
                    <MudCheckBox T="bool" @bind-Checked="rememberMe"
                                 Label="Remember me"
                                 Color="Color.Primary"
                                 Style="color: #003262" />
                    <MudLink Color="Color.Primary" Style="font-size: 0.85rem;">
                        Forgot Password?
                    </MudLink>
                </MudStack>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="!isValid"
                           Style="border-radius: 50px; padding: 14px; font-weight: 600;background:#003262;">
                    Login
                </MudButton>

            </MudForm>

            <MudText Align="Align.Center" Typo="Typo.body2" Class="mt-4">
                Don't have an account?
                <MudLink Href="/register">Sign Up</MudLink>
            </MudText>

        </div>

    </div>

</MudPaper>

@code {
    MudForm form = default!;
    bool isValid;
    bool rememberMe;
    public string username = "";
    public string password = "";

    InputType pwdType = InputType.Password;
    string pwdIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePassword()
    {
        if (pwdType == InputType.Password)
        {
            pwdType = InputType.Text;
            pwdIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            pwdType = InputType.Password;
            pwdIcon = Icons.Material.Filled.VisibilityOff;
        }
    }


}
