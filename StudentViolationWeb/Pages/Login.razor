@page "/"
@page "/login"
@using StudentViolationWeb.Data
@inject NavigationManager Nav
@inject AuthService AuthService
@inject HttpClient Http
@inject ISnackbar Snackbar



<div style="display: flex; height: 100vh; width: 100%; font-family: 'Segoe UI', sans-serif; background-image: linear-gradient(135deg,#F9FAFB 0% , #0057B8 0%, #F9FAFB 100%); ">

    @*left *@
    <div style="width: 45%;  display: flex; flex-direction: column;
                align-items: center; justify-content: center; padding: 60px 80px; flex-shrink: 0;">

        <img src="Image/aclc_logo.png"
             alt="ACLC Logo"
             style="width: 120px; height: auto;" />
        <MudText Typo="Typo.h6" Align="Align.Center"
                 Style="color: #EEEEEE; font-weight: 500; margin-bottom: 8px; letter-spacing: 2px; text-transform: uppercase;">
            ACLC College of Mandaue
        </MudText>
        <MudText Typo="Typo.h3" Align="Align.Center"
                 Style="color: #EEEEEE; font-weight: 800; margin-bottom: 20px; line-height: 1.2;">
            Student Violation System
        </MudText>

    </div>

    @* right *@
    <div style="flex: 1; display: flex; flex-direction: column;
                align-items: center; justify-content: center;
                background: rgba(255,255,255,0.00); padding: 60px 80px; overflow-y: auto;">

        <div style="width: 100%; max-width: 480px;
                background: rgba(0, 87, 184, 0.10);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border: 1px solid rgba(17,24,39,0.15);
                border-radius: 20px;
                padding: 48px 40px;
                box-shadow: 0 8px 32px rgba(250,250,250,0.15);">

            <MudText Typo="Typo.h4" Style="color: white; font-weight: 700; margin-bottom: 8px;">
                Welcome back
            </MudText>
            <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.5); margin-bottom: 40px;">
                Sign in to your account to continue
            </MudText>

            <MudForm @ref="form" @bind-IsValid="isValid">

                <MudText Style="color: #EEEEEE; font-size: 0.85rem; margin-bottom: 6px;">Username</MudText>
                <MudTextField T="string"
                              @bind-Value="username"
                              Required="true"
                              RequiredError="Username is required"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              Class="mb-5"
                              Style="color: #EEEEEE;"
                              InputStyle="color: default;" />

                <MudText Style="color: #EEEEEE; font-size: 0.85rem; margin-bottom: 6px;">Password</MudText>
                <MudTextField T="string"
                              @bind-Value="password"
                              Required="true"
                              RequiredError="Password is required"
                              InputType="@pwdType"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@pwdIcon"
                              OnAdornmentClick="TogglePassword"
                              Class="mb-4"
                              Style="color: #EEEEEE;"
                              InputStyle="color: default;" />

                <MudStack Row="true" Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center" Class="mb-6">
                    <MudCheckBox T="bool" @bind-Checked="rememberMe"
                                 Label="Remember me"
                                 Color="Color.Inherit"
                                 Style="color: #EEEEEE;" />
                    <MudLink Color="Color.Default"
                             Style="font-size: 0.85rem; color: #111827; cursor: pointer;">
                        Forgot Password?
                    </MudLink>
                </MudStack>

                @if (isLoading)
                {
                    <MudButton Variant="Variant.Filled"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="true"
                               Style="background: #111827; color: #EEEEEE; font-weight: 700;
                                          font-size: 1rem; border-radius: 8px; padding: 16px;
                                          text-transform: none; letter-spacing: 0;">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="margin-right: 8px;" />
                        Signing In...
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="!isValid"
                               OnClick="HandleLogin"
                               Style="background: #111827; color: #EEEEEE; font-weight: 700;
                                          font-size: 1rem; border-radius: 8px; padding: 16px;
                                          text-transform: none; letter-spacing: 0;">
                        Sign In
                    </MudButton>
                }

            </MudForm>

            <MudDivider Style="border-color: rgba(17,24,39,0.15);margin: 32px 0;" />

            <MudText Align="Align.Center" Style="color:#EEEEEE; font-size: 0.9rem;">
                Don't have an account?
                <MudLink Href="/register"
                         Color="Color.Inherit"
                         Style="color: #0057B8; font-weight: 700; margin-left: 4px;">
                    Create Account
                </MudLink>
            </MudText>

        </div>
    </div>

</div>

@code {
    MudForm form = default!;
    bool isValid;
    bool isLoading;
    bool rememberMe;
    public string username = "";
    public string password = "";

    InputType pwdType = InputType.Password;
    string pwdIcon = Icons.Material.Filled.VisibilityOff;

    void TogglePassword()
    {
        if (pwdType == InputType.Password)
        {
            pwdType = InputType.Text;
            pwdIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            pwdType = InputType.Password;
            pwdIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    async Task HandleLogin()
    {
        await form.Validate();
        if (!isValid) return;

        isLoading = true;

        try
        {
            var loginModel = new LoginModel { Username = username.Trim().ToLower(), Password = password.Trim() };
            var result = await AuthService.LoginAsync(loginModel);

            if (result != null && result.Status == 200 && result.Data != null)
            {
                switch (result.Data.Role)
                {
                    case "Student":
                        Nav.NavigateTo("/student/dashboard");
                        break;
                    case "Guard":
                        Nav.NavigateTo("/guard");
                        break;
                    case "Guidance":
                        Nav.NavigateTo("/guidance");
                        break;
                    case "Sao":
                        Nav.NavigateTo("/sao");
                        break;
                    default:
                        Nav.NavigateTo("/");
                        break;
                }
            }
            else
            {
                Snackbar.Add(result?.Message ?? "Invalid username or password.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
