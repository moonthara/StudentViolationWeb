@page "/register"
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<div style="display: flex; min-height: 100vh; width: 100%; font-family: 'Segoe UI', sans-serif; background: #003262;">

    @*left*@
    <div style="width: 35%; background: rgba(0,0,0,0.2); display: flex; flex-direction: column;
                align-items: center; justify-content: center; padding: 60px 48px; flex-shrink: 0;
                border-right: 1px solid rgba(255,255,255,0.1); position: sticky; top: 0; height: 100vh;">

        <MudIcon Icon="@Icons.Material.Filled.School"
                 Style="font-size: 90px; color: white; margin-bottom: 20px;" />
        <MudText Typo="Typo.subtitle1" Align="Align.Center"
                 Style="color: rgba(255,255,255,0.7); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px;">
            ACLC College of Mandaue
        </MudText>
        <MudText Typo="Typo.h4" Align="Align.Center"
                 Style="color: white; font-weight: 800; margin-bottom: 16px; line-height: 1.3;">
            Student Violation System
        </MudText>
        

    </div>

    @*right*@
    <div style="flex: 1; overflow-y: auto; padding: 60px 80px;">
        <div style="max-width: 680px; margin: 0 auto;">

            <MudText Typo="Typo.h4" Style="color: white; font-weight: 700; margin-bottom: 8px;">
                Create Account
            </MudText>
            <MudText Style="color: rgba(255,255,255,0.6); margin-bottom: 40px;">
                Fill in the details below to register your account.
            </MudText>

            <MudForm @ref="form" @bind-IsValid="isValid">

                @*role*@
                <MudText Typo="Typo.overline"
                         Style="color: rgba(255,255,255,0.5); letter-spacing: 2px;">
                    Select Role
                </MudText>
                <MudDivider Style="border-color: rgba(255,255,255,0.15); margin-bottom: 20px;" />

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px; margin-bottom: 36px;">

                    <div @onclick="@(() => model.Role = "Student")"
                         style="@($"display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px 12px; border-radius: 12px; cursor: pointer; border: 2px solid {(model.Role == "Student" ? "white" : "rgba(255,255,255,0.15)")}; background: {(model.Role == "Student" ? "rgba(255,255,255,0.15)" : "rgba(255,255,255,0.05)")};")">
                        <MudIcon Icon="@Icons.Material.Filled.School"
                                 Style="@($"font-size: 32px; margin-bottom: 8px; color: {(model.Role == "Student" ? "white" : "rgba(255,255,255,0.5)")}")" />
                        <MudText Style="@($"font-size: 0.8rem; font-weight: {(model.Role == "Student" ? "700" : "400")}; color: {(model.Role == "Student" ? "white" : "rgba(255,255,255,0.6)")}")">Student</MudText>
                    </div>

                    <div @onclick="@(() => model.Role = "Guard")"
                         style="@($"display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px 12px; border-radius: 12px; cursor: pointer; border: 2px solid {(model.Role == "Guard" ? "white" : "rgba(255,255,255,0.15)")}; background: {(model.Role == "Guard" ? "rgba(255,255,255,0.15)" : "rgba(255,255,255,0.05)")};")">
                        <MudIcon Icon="@Icons.Material.Filled.Security"
                                 Style="@($"font-size: 32px; margin-bottom: 8px; color: {(model.Role == "Guard" ? "white" : "rgba(255,255,255,0.5)")}")" />
                        <MudText Style="@($"font-size: 0.8rem; font-weight: {(model.Role == "Guard" ? "700" : "400")}; color: {(model.Role == "Guard" ? "white" : "rgba(255,255,255,0.6)")}")">Guard</MudText>
                    </div>

                    <div @onclick="@(() => model.Role = "SAO")"
                         style="@($"display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px 12px; border-radius: 12px; cursor: pointer; border: 2px solid {(model.Role == "SAO" ? "white" : "rgba(255,255,255,0.15)")}; background: {(model.Role == "SAO" ? "rgba(255,255,255,0.15)" : "rgba(255,255,255,0.05)")};")">
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings"
                                 Style="@($"font-size: 32px; margin-bottom: 8px; color: {(model.Role == "SAO" ? "white" : "rgba(255,255,255,0.5)")}")" />
                        <MudText Style="@($"font-size: 0.8rem; font-weight: {(model.Role == "SAO" ? "700" : "400")}; color: {(model.Role == "SAO" ? "white" : "rgba(255,255,255,0.6)")}")">SAO</MudText>
                    </div>

                    <div @onclick="@(() => model.Role = "Guidance")"
                         style="@($"display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px 12px; border-radius: 12px; cursor: pointer; border: 2px solid {(model.Role == "Guidance" ? "white" : "rgba(255,255,255,0.15)")}; background: {(model.Role == "Guidance" ? "rgba(255,255,255,0.15)" : "rgba(255,255,255,0.05)")};")">
                        <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount"
                                 Style="@($"font-size: 32px; margin-bottom: 8px; color: {(model.Role == "Guidance" ? "white" : "rgba(255,255,255,0.5)")}")" />
                        <MudText Style="@($"font-size: 0.8rem; font-weight: {(model.Role == "Guidance" ? "700" : "400")}; color: {(model.Role == "Guidance" ? "white" : "rgba(255,255,255,0.6)")}")">Guidance</MudText>
                    </div>

                </div>

                
                <MudText Typo="Typo.overline"
                         Style="color: rgba(255,255,255,0.5); letter-spacing: 2px;">
                    Account Info
                </MudText>
                <MudDivider Style="border-color: rgba(255,255,255,0.15); margin-bottom: 20px;" />

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                    <MudTextField T="string" Label="Username"
                                  @bind-Value="model.Username"
                                  Required="true" RequiredError="Required"
                                  Variant="Variant.Outlined"
                                  InputStyle="color: white;" Style="color:white;" />

                    <MudTextField T="string" Label="Email"
                                  @bind-Value="model.Email"
                                  Required="true" RequiredError="Required"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  InputStyle="color: white;" Style="color:white;" />
                </div>

                <MudTextField T="string" Label="Password"
                              @bind-Value="model.Password"
                              Required="true" RequiredError="Required"
                              InputType="@pwdType"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@pwdIcon"
                              OnAdornmentClick="TogglePassword"
                              Class="mb-8"
                              InputStyle="color: white;" Style="color:white;" />

                
                <MudText Typo="Typo.overline"
                         Style="color: rgba(255,255,255,0.5); letter-spacing: 2px;">
                    Personal Info
                </MudText>
                <MudDivider Style="border-color: rgba(255,255,255,0.15); margin-bottom: 20px;" />

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                    <MudTextField T="string" Label="First Name"
                                  @bind-Value="model.FirstName"
                                  Required="true" RequiredError="Required"
                                  Variant="Variant.Outlined"
                                  InputStyle="color: white;" Style="color:white;" />

                    <MudTextField T="string" Label="Last Name"
                                  @bind-Value="model.LastName"
                                  Required="true" RequiredError="Required"
                                  Variant="Variant.Outlined"
                                  InputStyle="color: white;" Style="color:white;" />

                    <MudDatePicker Label="Date of Birth"
                                   @bind-Date="model.DateOfBirth"
                                   Variant="Variant.Outlined"
                                   Style="color: white;"
                                   InputStyle="color: white;" />

                    <MudSelect T="string" Label="Gender"
                               @bind-Value="model.Gender"
                               Variant="Variant.Outlined"
                               Style="color: white;" InputStyle="color: white;">
                        <MudSelectItem Value="@("Male")">Male</MudSelectItem>
                        <MudSelectItem Value="@("Female")">Female</MudSelectItem>
                        <MudSelectItem Value="@("Other")">Other</MudSelectItem>
                    </MudSelect>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 36px;">
                    <MudTextField T="string" Label="Address"
                                  @bind-Value="model.Address"
                                  Required="true" RequiredError="Required"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Home"
                                  InputStyle="color: white;" Style="color:white;" />

                    <MudTextField T="string" Label="Phone Number"
                                  @bind-Value="model.Number"
                                  Required="true" RequiredError="Required"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Phone"
                                  InputStyle="color: white;" Style="color:white;" />
                </div>

                @* student_info *@
                @if (model.Role == "Student")
                {
                    <MudText Typo="Typo.overline"
                             Style="color: rgba(255,255,255,0.5); letter-spacing: 2px;">
                        Student Info
                    </MudText>
                    <MudDivider Style="border-color: rgba(255,255,255,0.15); margin-bottom: 20px;" />

                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 36px;">
                        <MudTextField T="string" Label="Student No."
                                      @bind-Value="model.StudentNo"
                                      Required="true" RequiredError="Required"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Badge"
                                      InputStyle="color: white;" Style="color:white;" />

                        <MudTextField T="string" Label="Course"
                                      @bind-Value="model.Course"
                                      Required="true" RequiredError="Required"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.MenuBook"
                                      InputStyle="color: white;" Style="color:white;" />

                        <MudSelect T="string" Label="Year Level"
                                   @bind-Value="model.Year"
                                   Variant="Variant.Outlined"
                                   Style="color: white;" InputStyle="color: white;">
                            <MudSelectItem Value="@("1st Year")">1st Year</MudSelectItem>
                            <MudSelectItem Value="@("2nd Year")">2nd Year</MudSelectItem>
                            <MudSelectItem Value="@("3rd Year")">3rd Year</MudSelectItem>
                            <MudSelectItem Value="@("4th Year")">4th Year</MudSelectItem>
                        </MudSelect>
                    </div>
                }

            </MudForm>

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleRegister"
                       Disabled="!isValid || isLoading || string.IsNullOrEmpty(model.Role)"
                       Style="background: white; color: #003262; font-weight: 700;
                              font-size: 1rem; border-radius: 8px; padding: 16px;
                              text-transform: none; letter-spacing: 0; margin-bottom: 20px;">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="margin-right: 8px;" />
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </MudButton>

            <MudText Align="Align.Center"
                     Style="color: rgba(255,255,255,0.6); font-size: 0.9rem; padding-bottom: 40px;">
                Already have an account?
                <MudLink Href="/login"
                         Style="color: white; font-weight: 700; text-decoration: underline; margin-left: 4px;">
                    Sign In
                </MudLink>
            </MudText>

        </div>
    </div>

</div>

@code {
    MudForm form = default!;
    bool isValid;
    bool isLoading;

    InputType pwdType = InputType.Password;
    public string pwdIcon = Icons.Material.Filled.VisibilityOff;

    RegisterModel model = new();

    void TogglePassword()
    {
        if (pwdType == InputType.Password)
        {
            pwdType = InputType.Text;
            pwdIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            pwdType = InputType.Password;
            pwdIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    async Task HandleRegister()
    {
        await form.Validate();
        if (!isValid) return;

        isLoading = true;

        
        // if (model.Role == "Student")
        //     await AuthService.RegisterStudentAsync(model);
        // else
        //     await AuthService.RegisterStaffAsync(model);

        Snackbar.Add("Account created successfully!", Severity.Success);
        Nav.NavigateTo("/login");

        isLoading = false;
    }

    class RegisterModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public DateTime? DateOfBirth { get; set; }
        public string Gender { get; set; } = "";
        public string Address { get; set; } = "";
        public string Number { get; set; } = "";
        public string Role { get; set; } = "";
        public string StudentNo { get; set; } = "";
        public string Course { get; set; } = "";
        public string Year { get; set; } = "";
    }
}