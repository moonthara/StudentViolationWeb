@page "/sao/"
@implements IDisposable
@inject NavigationManager Nav
@inject AuthService AuthService
@inject SaoService SaoService
@inject ISnackbar Snackbar

<PageTitle>SAO Dashboard</PageTitle>

<MudLayout>

    @* AppBar *@
    <MudAppBar Elevation="0"
               Style="background:rgba(255,255,255,0.95);
                      backdrop-filter:blur(20px);
                      border-bottom:1px solid #E1F5FE;">

        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick='() => Nav.NavigateTo("/login")'
                       Style="color:#546E7A;" />
        <MudSpacer />

        <MudText Typo="Typo.h6"
                 Style="font-weight:700; color:#0288D1; letter-spacing:0.02em;">
            SAO Dashboard
        </MudText>

        <MudSpacer />

        <MudText Typo="Typo.caption"
                 Style="color:#90A4AE; font-size:11px; margin-right:4px;">
            @_currentTime
        </MudText>

        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       OnClick="Logout"
                       Style="color:#546E7A;" />
    </MudAppBar>

    @* main *@
    <MudMainContent Style="background:#F4F9FD; min-height:100vh; padding-bottom:80px;">

        <div style="position:fixed; inset:0;
                    background:
                        radial-gradient(ellipse 60% 50% at 0% 0%,  #E1F5FE 0%, transparent 60%),
                        radial-gradient(ellipse 40% 40% at 100% 100%, #B3E5FC 0%, transparent 60%);
                    pointer-events:none; z-index:0;"></div>
        <div style="position:fixed; inset:0;
                    background-image:radial-gradient(#B3E5FC 1px, transparent 1px);
                    background-size:24px 24px;
                    pointer-events:none; z-index:0; opacity:0.45;"></div>

        <div style="position:relative; z-index:1; padding:16px 16px 0;">

            @* welcome *@
            @if (_activeTab == 0)
            {
                <div style="background:linear-gradient(135deg,#FFFFFF,#E1F5FE);
                            border:1px solid #B3E5FC; border-radius:16px;
                            padding:16px 20px; margin-bottom:18px;
                            display:flex; align-items:center; gap:16px;
                            box-shadow:0 4px 12px rgba(2,136,209,0.08);">
                    <div style="width:44px; height:44px; border-radius:12px;
                                background:#0288D1;
                                display:flex; align-items:center; justify-content:center;
                                flex-shrink:0;
                                box-shadow:0 4px 8px rgba(2,136,209,0.25);">
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings"
                                 Style="color:#FFFFFF; font-size:22px;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.subtitle1"
                                 Style="font-weight:700; color:#0288D1; font-size:14px;">
                            Welcome, Login successful!
                        </MudText>
                        <MudText Typo="Typo.caption"
                                 Style="color:#546E7A; font-size:11px;">
                            Student Affairs Office
                        </MudText>
                    </div>
                </div>
            }

            @* panel *@
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
                <div style="width:4px; height:20px;
                            background:@_accentColor;
                            border-radius:4px;"></div>
                <MudIcon Icon="@_panelIcon"
                         Style="@($"color:{_accentColor}; font-size:19px;")" />
                <MudText Typo="Typo.subtitle1"
                         Style="font-weight:700; color:#1A237E; font-size:15px;">
                    @_panelTitle
                </MudText>
            </div>

           @* violation *@
            @if (_activeTab == 0)
            {
                @* stats_row *@
                <div style="display:flex; gap:8px; margin-bottom:14px;">
                    @foreach (var stat in new[] {
                        (_totalViolations.ToString(),    "Total",    "#1A237E", "#C5CAE9"),
                        (_pendingViolations.ToString(),  "Pending",  "#F9A825", "#FFE082"),
                        (_approvedViolations.ToString(), "Approved", "#2E7D32", "#A5D6A7"),
                        (_rejectedViolations.ToString(), "Rejected", "#E53935", "#FFCDD2")
                    })
                    {
                        <div style="flex:1; background:#FFFFFF;
                                    border:1px solid @stat.Item4;
                                    border-radius:12px; padding:10px 8px;
                                    text-align:center;
                                    box-shadow:0 2px 6px rgba(2,136,209,0.06);">
                            <MudText Style="font-size:1.4rem; font-weight:700; color:#1A237E; line-height:1.1;">
                                @stat.Item1
                            </MudText>
                            <MudText Style="font-size:0.68rem; color:#90A4AE; margin-top:2px; font-weight:600; text-transform:uppercase; letter-spacing:0.04em;">
                                @stat.Item2
                            </MudText>
                        </div>
                    }
                </div>

                @* violation_card *@
                <div style="display:flex; gap:8px; margin-bottom:14px; flex-wrap:wrap;">
                    @foreach (var f in new[] { "All", "Pending", "Approved", "Rejected" })
                    {
                        <button @onclick="() => SetFilter(f)"
                                style="padding:6px 16px; border-radius:20px; font-size:12px;
                                       font-weight:@(_activeFilter == f ? "700" : "500");
                                       border:1px solid @(_activeFilter == f ? "#1A237E" : "#B3E5FC");
                                       background:@(_activeFilter == f ? "#1A237E" : "#FFFFFF");
                                       color:@(_activeFilter == f ? "#FFFFFF" : "#546E7A");
                                       cursor:pointer;">
                            @f
                        </button>
                    }
                </div>

                @* violation *@
                <div style = "display:flex; flex-direction:column; gap:10px;" >
                                @if(_violations.Count == 0);
                {
                        <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                                    border-radius:16px; padding:40px; text-align:center;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline"
                                     Style="color:#CFD8DC; font-size:48px;" />
                            <MudText Typo="Typo.caption"
                                     Style="display:block; color:#90A4AE; margin-top:8px;">
                                No violations found
                            </MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var v in FilteredViolations)
                        {
                            <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                                        border-radius:14px; padding:14px 16px;
                                        box-shadow:0 2px 8px rgba(2,136,209,0.06);">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:6px;">
                                    <MudText Style="font-size:13px; font-weight:700; color:#1A237E;">
                                        @v.ViolationName
                                    </MudText>
                                    <div style="display:flex; gap:6px;">
                                        <span style="@SeverityBadgeStyle(v.Severity)">@v.Severity</span>
                                        <span style="@StatusBadgeStyle(v.Status)">@v.Status</span>
                                    </div>
                                </div>
                                <MudText Style="font-size:11px; color:#546E7A; margin-bottom:2px;">
                                    @v.StudentNo
                                </MudText>
                                <MudText Style="font-size:11px; color:#90A4AE; margin-bottom:4px;">
                                    @v.ViolationDate.ToString("yyyy-MM-dd")
                                </MudText>
                                 @if (!string.IsNullOrEmpty(v.Description))
                                 {
                                     <MudText Style="font-size:11px; color:#546E7A; font-style:italic;">
                                         @v.Description
                                     </MudText>
                                 }

                                
                                <div style="display:flex; align-items:center; justify-content:flex-end; gap:8px; margin-top:10px;">
                                    @if (v.Status == "Pending")
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   OnClick="() => ApproveViolation(v)"
                                                   Style="border-color:#2E7D32; color:#2E7D32;
                                                          border-radius:8px; font-weight:700;
                                                          text-transform:none; font-size:12px;
                                                          padding:4px 14px; min-width:0;">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Style="font-size:14px; margin-right:4px;" />
                                            Approve
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   OnClick="() => RejectViolation(v)"
                                                   Style="border-color:#E53935; color:#E53935;
                                                          border-radius:8px; font-weight:700;
                                                          text-transform:none; font-size:12px;
                                                          padding:4px 14px; min-width:0;">
                                            <MudIcon Icon="@Icons.Material.Filled.Cancel"
                                                     Style="font-size:14px; margin-right:4px;" />
                                            Reject
                                        </MudButton>
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Style="color:#0288D1; padding:4px;" Size="Size.Small"
                                                   OnClick="() => EditViolation(v)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Style="color:#90A4AE; padding:4px;" Size="Size.Small"
                                                   OnClick="() => DeleteViolation(v)" />
                                </div>
                            </div>
                        }
                    }
                </div>
            }

            @* summary *@
            @if (_activeTab == 1)
            {
                
                <div style="display:flex; gap:8px; margin-bottom:14px;">
                    @foreach (var stat in new[] {
                        (_totalViolations.ToString(),    "Total",    "#1A237E", "#C5CAE9"),
                        (_pendingViolations.ToString(),  "Pending",  "#F9A825", "#FFE082"),
                        (_approvedViolations.ToString(), "Approved", "#2E7D32", "#A5D6A7"),
                        (_rejectedViolations.ToString(), "Rejected", "#E53935", "#FFCDD2")
                    })
                    {
                        <div style="flex:1; background:#FFFFFF;
                                    border:1px solid @stat.Item4;
                                    border-radius:12px; padding:10px 8px;
                                    text-align:center;
                                    box-shadow:0 2px 6px rgba(2,136,209,0.06);">
                            <MudText Style="font-size:1.4rem; font-weight:700; color:#1A237E; line-height:1.1;">
                                @stat.Item1
                            </MudText>
                            <MudText Style="font-size:0.68rem; color:#90A4AE; margin-top:2px; font-weight:600; text-transform:uppercase; letter-spacing:0.04em;">
                                @stat.Item2
                            </MudText>
                        </div>
                    }
                </div>

                @* severity *@
                <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                            border-radius:14px; padding:14px 16px; margin-bottom:10px;
                            box-shadow:0 2px 8px rgba(2,136,209,0.06);">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                        <div style="width:3px; height:16px; background:#0288D1; border-radius:4px;"></div>
                        <MudIcon Icon="@Icons.Material.Filled.BarChart"
                                 Style="color:#0288D1; font-size:17px;" />
                        <MudText Style="font-size:13px; font-weight:700; color:#1A237E;">
                            By Severity
                        </MudText>
                    </div>
                    @foreach (var item in _bySeverity)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center;
                                    padding:6px 0; border-bottom:1px solid #F0F7FF;">
                            <div style="display:flex; align-items:center; gap:8px;">
                                <div style="width:8px; height:8px; border-radius:50%; background:#0288D1;"></div>
                                <MudText Style="font-size:13px; color:#546E7A;">@item.Key</MudText>
                            </div>
                            <MudText Style="font-size:13px; font-weight:700; color:#0288D1;">@item.Value</MudText>
                        </div>
                    }
                </div>

                @* violation_type *@
                <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                            border-radius:14px; padding:14px 16px; margin-bottom:10px;
                            box-shadow:0 2px 8px rgba(2,136,209,0.06);">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                        <div style="width:3px; height:16px; background:#F9A825; border-radius:4px;"></div>
                        <MudIcon Icon="@Icons.Material.Filled.Assignment"
                                 Style="color:#F9A825; font-size:17px;" />
                        <MudText Style="font-size:13px; font-weight:700; color:#1A237E;">
                            By Violation Type
                        </MudText>
                    </div>
                    @foreach (var item in _byType)
                    {
                        <div style="display:flex; justify-content:space-between; align-items:center;
                                    padding:6px 0; border-bottom:1px solid #F0F7FF;">
                            <div style="display:flex; align-items:center; gap:8px;">
                                <div style="width:8px; height:8px; border-radius:50%; background:#546E7A;"></div>
                                <MudText Style="font-size:13px; color:#546E7A;">@item.Key</MudText>
                            </div>
                            <MudText Style="font-size:13px; font-weight:700; color:#1A237E;">@item.Value</MudText>
                        </div>
                    }
                </div>

                @* student_report *@
                <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                            border-radius:14px; padding:14px 16px; margin-bottom:14px;
                            box-shadow:0 2px 8px rgba(2,136,209,0.06);">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                        <div style="width:3px; height:16px; background:#2E7D32; border-radius:4px;"></div>
                        <MudIcon Icon="@Icons.Material.Filled.ManageSearch"
                                 Style="color:#2E7D32; font-size:17px;" />
                        <MudText Style="font-size:13px; font-weight:700; color:#1A237E;">
                            Student Report
                        </MudText>
                    </div>
                    <div style="background:#F4F9FD; border:1px solid #E1F5FE;
                                border-radius:10px; padding:10px 14px;
                                display:flex; align-items:center; gap:10px; margin-bottom:12px;">
                        <MudIcon Icon="@Icons.Material.Filled.PersonSearch"
                                 Style="color:#90A4AE; font-size:18px;" />
                        <MudTextField @bind-Value="_reportStudentNo"
                                      Placeholder="Enter StudentNo for full report"
                                      Variant="Variant.Text" Dense="true"
                                      Style="flex:1;" />
                    </div>
                    <MudButton Variant="Variant.Filled"
                               OnClick="GetStudentReport"
                               Disabled="_reportLoading"
                               FullWidth="true"
                               Style="background:#1A237E; color:#FFFFFF;
                                      border-radius:10px; font-weight:700;
                                      text-transform:none; padding:12px;
                                      box-shadow:0 4px 14px rgba(26,35,126,0.3);">
                        @if (_reportLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Style="color:#FFFFFF; margin-right:8px;" />
                            <span>Loading...</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Search"
                                     Style="font-size:18px; margin-right:8px;" />
                            <span>Get Report</span>
                        }
                    </MudButton>
                </div>
            }

            @* users *@
            @if (_activeTab == 2)
            {
                <div style="background:#FFFFFF; border:1px solid #E1F5FE;
                            border-radius:16px; overflow:hidden;
                            box-shadow:0 2px 10px rgba(2,136,209,0.06);">

                    @if (_users.Count == 0)
                    {
                        <div style="padding:40px; text-align:center;">
                            <MudIcon Icon="@Icons.Material.Filled.PeopleOutline"
                                     Style="color:#CFD8DC; font-size:48px;" />
                            <MudText Typo="Typo.caption"
                                     Style="display:block; color:#90A4AE; margin-top:8px;">
                                No users found
                            </MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var u in _users)
                        {
                            <div style="display:flex; align-items:center; gap:14px;
                                        padding:14px 18px;
                                        border-bottom:1px solid #F0F7FF;">
                                <div style="width:38px; height:38px; border-radius:50%;
                                            background:linear-gradient(135deg,#E1F5FE,#B3E5FC);
                                            border:1px solid #81D4FA;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:14px; font-weight:700; color:#0288D1;
                                            flex-shrink:0;">
                                    @u.FirstName[0]
                                </div>
                                <div style="flex:1; min-width:0;">
                                    <MudText Style="font-size:13px; font-weight:600;
                                                    color:#1A237E; white-space:nowrap;
                                                    overflow:hidden; text-overflow:ellipsis;">
                                        @u.FirstName @u.LastName
                                    </MudText>
                                    <MudText Style="font-size:11px; color:#90A4AE; margin-top:1px;">
                                        @u.StudentNo · @u.Course – @u.Year
                                    </MudText>
                                </div>
                                <span style="font-size:10px; font-weight:600;
                                             padding:2px 10px; border-radius:20px;
                                             background:#E1F5FE; border:1px solid #81D4FA;
                                             color:#0288D1; white-space:nowrap;">
                                    @u.Course
                                </span>
                            </div>
                        }
                    }
                </div>
            }

        </div>
    </MudMainContent>

    @* bottom_bar *@
    <div style="position:fixed; bottom:0; left:0; right:0; z-index:300;
                background:rgba(255,255,255,0.97); backdrop-filter:blur(24px);
                border-top:1px solid #E1F5FE;
                box-shadow:0 -4px 20px rgba(26,35,126,0.08);
                height:68px; display:flex; align-items:stretch; padding:0 8px;">

        <button @onclick="() => SetTab(0)" style="@NavBtnStyle(0)">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Style="@NavIconStyle(0)" />
            <span style="@NavLabelStyle(0)">Violations</span>
        </button>

        <button @onclick="() => SetTab(1)" style="@NavBtnStyle(1)">
            <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="@NavIconStyle(1)" />
            <span style="@NavLabelStyle(1)">Summary</span>
        </button>

        <button @onclick="() => SetTab(2)" style="@NavBtnStyle(2)">
            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Style="@NavIconStyle(2)" />
            <span style="@NavLabelStyle(2)">Users</span>
        </button>

    </div>

</MudLayout>


@code {

    private int _activeTab = 0;
    private string _currentTime = "";
    private System.Threading.Timer? _clockTimer;

    private string _activeFilter = "All";
    private List<ViolationModel> _violations = new();
    private List<StudentModel> _users = new();

    private int _totalViolations   => _violations.Count;
    private int _pendingViolations  => _violations.Count(v => v.Status == "Pending");
    private int _approvedViolations => _violations.Count(v => v.Status == "Approved");
    private int _rejectedViolations => _violations.Count(v => v.Status == "Rejected");

    private IEnumerable<ViolationModel> FilteredViolations => _activeFilter switch
    {
        "Pending"  => _violations.Where(v => v.Status == "Pending"),
        "Approved" => _violations.Where(v => v.Status == "Approved"),
        "Rejected" => _violations.Where(v => v.Status == "Rejected"),
        _          => _violations
    };

    private Dictionary<string, int> _bySeverity = new();
    private Dictionary<string, int> _byType     = new();

    private string _reportStudentNo = "";
    private bool _reportLoading = false;

    protected override async Task OnInitializedAsync()
    {
        UpdateClock();
        _clockTimer = new System.Threading.Timer(_ =>
        {
            UpdateClock();
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        // TODO: replace with actual service calls
        // _violations = await SaoService.GetViolationsAsync();
        // _users      = await SaoService.GetUsersAsync();
        await Task.CompletedTask;
    }

    private void UpdateClock() =>
        _currentTime = DateTime.Now.ToString("MMM d · h:mm tt");

    public void Dispose() => _clockTimer?.Dispose();

    private string _panelTitle => _activeTab switch
    {
        0 => "All Violations",
        1 => "Summary",
        2 => "Users",
        _ => ""
    };

    private string _panelIcon => _activeTab switch
    {
        0 => Icons.Material.Filled.Warning,
        1 => Icons.Material.Filled.BarChart,
        2 => Icons.Material.Filled.PeopleAlt,
        _ => Icons.Material.Filled.Dashboard
    };

    private string _accentColor => _activeTab switch
    {
        0 => "#0288D1",
        1 => "#0288D1",
        2 => "#0288D1",
        _ => "#0288D1"
    };

    private void SetTab(int idx)    => _activeTab = idx;
    private void SetFilter(string f) => _activeFilter = f;

    private string NavBtnStyle(int idx) =>
        "flex:1; display:flex; flex-direction:column; align-items:center; " +
        "justify-content:center; gap:3px; border:none; " +
        $"background:{(_activeTab == idx ? "#E8EAF6" : "transparent")}; " +
        "cursor:pointer; padding:6px 4px; border-radius:12px; height:56px;";

    private string NavIconStyle(int idx) =>
        $"font-size:20px; color:{(_activeTab == idx ? "#1A237E" : "#90A4AE")};";

    private string NavLabelStyle(int idx) =>
        $"font-size:10px; font-weight:{(_activeTab == idx ? "700" : "400")}; " +
        $"color:{(_activeTab == idx ? "#1A237E" : "#90A4AE")}; font-family:inherit;";

    private string SeverityBadgeStyle(string? severity) => severity switch
    {
        "MAJOR"    => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(249,168,37,0.12); border:1px solid rgba(249,168,37,0.4); color:#F9A825;",
        "CRITICAL" => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(229,57,53,0.10); border:1px solid rgba(229,57,53,0.4); color:#E53935;",
        "MODERATE" => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(156,39,176,0.10); border:1px solid rgba(156,39,176,0.35); color:#7B1FA2;",
        _          => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(2,136,209,0.10); border:1px solid rgba(2,136,209,0.35); color:#0288D1;"
    };

    private string StatusBadgeStyle(string? status) => status switch
    {
        "Approved" => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(46,125,50,0.10); border:1px solid rgba(46,125,50,0.35); color:#2E7D32;",
        "Pending"  => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(249,168,37,0.10); border:1px solid rgba(249,168,37,0.35); color:#F9A825;",
        _          => "padding:3px 10px; border-radius:20px; font-size:10px; font-weight:600; " +
                      "background:rgba(229,57,53,0.10); border:1px solid rgba(229,57,53,0.35); color:#E53935;"
    };

    private async Task ApproveViolation(ViolationModel v)
    {
        // TODO: await SaoService.ApproveViolationAsync(v.Id);
        v.Status = "Approved";
        Snackbar.Add("Violation approved.", Severity.Success);
        await Task.CompletedTask;
    }

    private async Task RejectViolation(ViolationModel v)
    {
        // TODO: await SaoService.RejectViolationAsync(v.Id);
        v.Status = "Rejected";
        Snackbar.Add("Violation rejected.", Severity.Warning);
        await Task.CompletedTask;
    }

    private void EditViolation(ViolationModel v) { /* TODO: open edit dialog */ }

    private async Task DeleteViolation(ViolationModel v)
    {
        // TODO: await SaoService.DeleteViolationAsync(v.Id);
        _violations.Remove(v);
        Snackbar.Add("Violation deleted.", Severity.Info);
        await Task.CompletedTask;
    }

    private async Task GetStudentReport()
    {
        if (string.IsNullOrWhiteSpace(_reportStudentNo)) return;
        _reportLoading = true;
        // TODO: var report = await SaoService.GetStudentReportAsync(_reportStudentNo.Trim().ToUpper());
        await Task.Delay(500);
        _reportLoading = false;
        Snackbar.Add($"Report loaded for {_reportStudentNo.Trim().ToUpper()}", Severity.Success);
    }

    private async Task Logout()
    {
        await AuthService.Logout();
        Nav.NavigateTo("/login");
    }
}
