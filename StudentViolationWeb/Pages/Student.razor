@page "/student"

@inject NavigationManager Nav
@inject HttpClient Http
@inject AuthService AuthService
@inject ISnackbar Snackbar

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 8px 16px; min-width: 80px; background: #1565c0;">

    <MudLayout Style="background: linear-gradient(#4988C4);">
        <MudAppBar Elevation="0" Style="background: rgba(255, 255, 255, 0.15) !important; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">

            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Style="color: #F9F7F7"
                           Edge="Edge.Start"
                           OnClick="GoBack" />

            <MudSpacer />

            <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: 0.5px; color: #F9F7F7;">
                Student Dashboard
            </MudText>

            <MudSpacer />

            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Style="color: #F9F7F7"
                           Edge="Edge.End"
                           OnClick="Logout" />
        </MudAppBar>
    </MudLayout>

    <MudMainContent>
        <MudTabs @bind-ActivePanelIndex="_activeTab"
                 Elevation="0"
                 Centered="true"
                 Style="background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(12px);"
                 SliderColor="Color.Error"
                 PanelClass="pa-4">

            <!-- ========== DASHBOARD TAB ========== -->
            <MudTabPanel>
                <TabContent>
                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width: 33vw; padding: 8px 0;">
                        <MudIcon Icon="@Icons.Material.Filled.Dashboard" Style="color:midnightblue;" />
                        <MudText Style="color:midnightblue; font-size:0.75rem; margin-top:2px;">Dashboard</MudText>
                    </div>
                </TabContent>
                <ChildContent>
                    <MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

                        <!-- Welcome Card -->
                        <MudPaper Style="background: linear-gradient(135deg, #1a237e 0%, #283593 60%, #1565c0 100%); border-radius: 12px; padding: 16px; margin-bottom: 16px;">
                            <div style="display:flex; align-items:center; gap:16px;">
                                <MudAvatar Style="background:rgba(255,255,255,0.2); width:48px; height:48px;">
                                    <MudIcon Icon="@Icons.Material.Filled.School" Style="color:white;" />
                                </MudAvatar>
                                <div>
                                    <MudText Style="color:white; font-weight:700; font-size:1rem;">
                                        Welcome, @(_student?.FirstName ?? "Student")!
                                    </MudText>
                                    <MudText Style="color:rgba(255,255,255,0.7); font-size:0.8rem;">
                                        Student Portal
                                    </MudText>
                                </div>
                            </div>
                        </MudPaper>

                        <!-- Stats Grid -->
                        <MudGrid Class="mb-3" Spacing="2">
                            <MudItem xs="3">
                                <MudPaper Class="pa-3" Style="border-radius:10px; text-align:center;">
                                    <MudText Style="font-size:1.5rem; font-weight:700; color:#212121;">@_totalViolations</MudText>
                                    <MudText Style="font-size:0.75rem; color:#757575;">Total</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="3">
                                <MudPaper Class="pa-3" Style="border-radius:10px; text-align:center;">
                                    <MudText Style="font-size:1.5rem; font-weight:700; color:#FF9800;">@_pendingViolations</MudText>
                                    <MudText Style="font-size:0.75rem; color:#FF9800;">Pending</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="3">
                                <MudPaper Class="pa-3" Style="border-radius:10px; text-align:center;">
                                    <MudText Style="font-size:1.5rem; font-weight:700; color:#4CAF50;">@_approvedViolations</MudText>
                                    <MudText Style="font-size:0.75rem; color:#757575;">Approved</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="3">
                                <MudPaper Class="pa-3" Style="border-radius:10px; text-align:center;">
                                    <MudText Style="font-size:1.5rem; font-weight:700; color:#F44336;">@_rejectedViolations</MudText>
                                    <MudText Style="font-size:0.75rem; color:#F44336;">Rejected</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>

                        <!-- ✅ WARNING LEVEL (Fixed Style Attributes) -->
                        <MudPaper Class="pa-3 mb-3"
                                  Style="@($"border-radius:10px; background:{GetWarningLevelBgColor()};")">
                            <div style="display:flex; align-items:center; gap:10px;">
                                <MudIcon Icon="@GetWarningLevelIcon()"
                                         Style="@($"color:{GetWarningLevelColor()};")" />
                                <div>
                                    <MudText Style="@($"color:{GetWarningLevelColor()}; font-weight:600; font-size:0.85rem;")">
                                        Warning Level: @GetWarningLevelText()
                                    </MudText>
                                    <MudText Style="color:#757575; font-size:0.78rem;">
                                        @GetWarningLevelMessage()
                                    </MudText>
                                </div>
                            </div>
                        </MudPaper>

                        <!-- Violation History Header -->
                        <div style="display:flex; align-items:center; gap:8px; margin-bottom:12px;">
                            <div style="width:4px; height:20px; background:#1a237e; border-radius:2px;"></div>
                            <MudText Style="font-weight:700; font-size:1rem; color:#212121;">Violation History</MudText>
                        </div>

                        <!-- Violation List -->
                        @if (_violations?.Any() == true)
                        {
                            @foreach (var v in _violations)
                            {
                                <MudPaper Class="pa-3 mb-2" Style="border-radius:10px;">
                                    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                        <div>
                                            <MudText Style="font-weight:600; font-size:0.9rem; color:#212121;">@v.ViolationName</MudText>
                                            <MudText Style="font-size:0.75rem; color:#9e9e9e;">@v.ViolationDate.ToString("yyyy-MM-dd")</MudText>
                                            <MudChip T="string" Size="Size.Small" Style="@GetStatusStyle(v.Status)">
                                                @v.Status
                                            </MudChip>
                                        </div>
                                        <MudChip T="string" Size="Size.Small"
                                                 Style="background:#e3f2fd; color:#1565c0; font-size:0.7rem; height:22px;">
                                            @v.Severity
                                        </MudChip>
                                    </div>
                                </MudPaper>
                            }
                        }
                        else
                        {
                            <MudText Style="color:#757575; font-style:italic;">No violations recorded.</MudText>
                        }

                    </MudContainer>
                </ChildContent>
            </MudTabPanel>

            <!-- ========== PROFILE TAB (Mapped to StudentModel.cs) ========== -->
            <MudTabPanel>
                <TabContent>
                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width: 33vw; padding: 8px 0;">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="color:midnightblue;" />
                        <MudText Style="color:midnightblue; font-size:0.75rem; margin-top:2px;">Profile</MudText>
                    </div>
                </TabContent>
                <ChildContent>
                    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-3">
                        <MudPaper Class="pa-4" Style="border-radius:12px;">
                            <div style="display:flex; flex-direction:column; align-items:center; margin-bottom:24px;">
                                <MudAvatar Style="background:#1565c0; width:80px; height:80px; font-size:1.5rem;">
                                    @(_student?.FirstName?.Substring(0, 1) ?? "S")@(_student?.LastName?.Substring(0, 1) ?? "T")
                                </MudAvatar>
                                <MudText Style="font-weight:700; font-size:1.2rem; margin-top:12px; color:#212121;">
                                    @(_student?.FirstName ?? "") @(_student?.LastName ?? "")
                                </MudText>
                                <MudText Style="color:#757575; font-size:0.9rem;">@_student?.StudentNo</MudText>
                            </div>

                            <MudDivider Class="mb-4" />

                            <MudList T="string" Dense="true">
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Course:</MudText>
                                    <MudText Style="margin-left:auto;">@_student?.Course</MudText>
                                </MudListItem>
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Year:</MudText>
                                    <MudText Style="margin-left:auto;">@_student?.Year</MudText>
                                </MudListItem>
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Email:</MudText>
                                    <MudText Style="margin-left:auto;">@_student?.Email</MudText>
                                </MudListItem>
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Gender:</MudText>
                                    <MudText Style="margin-left:auto;">@_student?.Gender</MudText>
                                </MudListItem>
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Contact:</MudText>
                                    <MudText Style="margin-left:auto;">@_student?.ContactNumber</MudText>
                                </MudListItem>
                                <MudListItem T="string">
                                    <MudText Style="font-weight:600; color:#1565c0;">Address:</MudText>
                                    <MudText Style="margin-left:auto; text-align:right; max-width:200px;">@_student?.Address</MudText>
                                </MudListItem>
                            </MudList>
                        </MudPaper>
                    </MudContainer>
                </ChildContent>
            </MudTabPanel>

            <!-- ========== QR CODE TAB ========== -->
            <MudTabPanel>
                <TabContent>
                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width: 33vw; padding: 8px 0;">
                        <MudIcon Icon="@Icons.Material.Filled.QrCode2" Style="color:midnightblue;" />
                        <MudText Style="color:midnightblue; font-size:0.75rem; margin-top:2px;">QR Code</MudText>
                    </div>
                </TabContent>
                <ChildContent>
                    <MudContainer MaxWidth="MaxWidth.Small" Class="pa-3" Style="display:flex; flex-direction:column; align-items:center;">
                        <MudPaper Class="pa-4" Style="border-radius:12px; text-align:center;">
                            <MudText Style="font-weight:600; margin-bottom:16px; color:#212121;">My QR Code</MudText>
                            <MudText Style="color:#757575; font-size:0.85rem; margin-bottom:16px;">
                                Show this to the Guard for scanning
                            </MudText>

                            <div style="width:200px; height:200px; background:white; border:2px solid #1565c0; border-radius:8px; margin:0 auto 16px; display:flex; align-items:center; justify-content:center;">
                                @if (!string.IsNullOrEmpty(_student?.QRCode))
                                {
                                    <img src="@_student.QRCode" style="width:180px; height:180px; object-fit:contain;" alt="QR Code" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.QrCode2" Style="font-size:120px; color:#1565c0;" />
                                }
                            </div>

                            <MudText Style="font-weight:600; color:#1565c0;">@_student?.StudentNo</MudText>
                            <MudText Style="color:#757575; font-size:0.9rem;">@(_student?.FirstName ?? "") @(_student?.LastName ?? "")</MudText>
                        </MudPaper>
                    </MudContainer>
                </ChildContent>
            </MudTabPanel>

        </MudTabs>
    </MudMainContent>
</div>

@code {
    private int _activeTab = 0;
    private List<ViolationModel> _violations = new();
    private StudentModel? _student;
    private int _totalViolations = 0;
    private int _pendingViolations = 0;
    private int _approvedViolations = 0;
    private int _rejectedViolations = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            // Load current student profile
            _student = await Http.GetFromJsonAsync<StudentModel>("api/students/current");

            // Load student violations
            _violations = await Http.GetFromJsonAsync<List<ViolationModel>>("api/violations/student") ?? new();

            // Calculate statistics
            _totalViolations = _violations.Count;
            _pendingViolations = _violations.Count(v => v.Status == "Pending");
            _approvedViolations = _violations.Count(v => v.Status == "Approved");
            _rejectedViolations = _violations.Count(v => v.Status == "Rejected");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading  {ex.Message}", Severity.Error);
        }
    }

    // ✅ DYNAMIC WARNING LEVEL LOGIC
    private string GetWarningLevelText() => _totalViolations switch
    {
        <= 2 => "Green",
        <= 5 => "Yellow",
        _ => "Red"
    };

    private string GetWarningLevelColor() => _totalViolations switch
    {
        <= 2 => "#4CAF50",
        <= 5 => "#FF9800",
        _ => "#F44336"
    };

    private string GetWarningLevelBgColor() => _totalViolations switch
    {
        <= 2 => "#e8f5e9",
        <= 5 => "#fff8e1",
        _ => "#ffebee"
    };

    private string GetWarningLevelIcon() => _totalViolations switch
    {
        <= 2 => Icons.Material.Filled.CheckCircle,
        <= 5 => Icons.Material.Filled.Warning,
        _ => Icons.Material.Filled.Error
    };

    private string GetWarningLevelMessage() => _totalViolations switch
    {
        <= 2 => "No action needed",
        <= 5 => "Please be mindful of school rules",
        _ => "Immediate attention required"
    };

    // ✅ Status Chip Styling
    private string GetStatusStyle(string status) => status switch
    {
        "Approved" => "background:#e8f5e9; color:#4CAF50; font-size:0.7rem; height:22px; margin-top:4px;",
        "Pending" => "background:#fff8e1; color:#FF9800; font-size:0.7rem; height:22px; margin-top:4px;",
        _ => "background:#ffebee; color:#F44336; font-size:0.7rem; height:22px; margin-top:4px;"
    };

    private void GoBack() => Nav.NavigateTo("/");
    private void Logout() => Nav.NavigateTo("/login");
}